{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "manjio",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-04",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/assets/r2/*"]
  },
  "r2_buckets": [
    {
      "binding": "R2_ASSETS",
      "bucket_name": "manjio-assets"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
