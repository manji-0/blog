{
  "filters": {
    "comments": true
  },
  "rules": {
    "preset-ja-technical-writing": {
      "no-mix-dearu-desumasu": {
        "preferDearu": true
      },
      "sentence-length": {
        "max": 160
      },
      "max-comma": {
        "max": 4
      },
      "max-ten": {
        "max": 4
      },
      "ja-no-mixed-period": {
        "periodMark": "。",
        "allowPeriodMarks": [":", "、"]
      },
      "max-kanji-continuous-len": {
        "max": 6,
        "allow": [
          "不透明代理集約",
          "保守性向上目的",
          "具体的契約価値",
          "判別共用体状態",
          "判別状態共用体",
          "安全性不変条件",
          "意味的依存関係",
          "明示的同期境界",
          "明示的安全表示",
          "明示的破壊的変更注記",
          "未定義動作検出",
          "未検証構築経路",
          "楕円曲線暗号鍵",
          "正規表現制約付",
          "段階的型安全性",
          "特定問題診断向",
          "状態機械遷移法則",
          "現実的負荷試験",
          "禁止部分文字列",
          "規程枚数以上自宅用",
          "超大規模集積回路",
          "遷移前提条件関数",
          "階層的品質比較",
          "静的状態安全性"
        ]
      },
      "no-exclamation-question-mark": false,
      "ja-no-weak-phrase": false
    }
  }
}
