    "beautiful-mermaid": "^1.1.3",
    "gray-matter": "^4.0.3",
    "kuromoji": "^0.1.2",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "wrangler": "^4.19.0"
  }
}
