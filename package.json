{
  "name": "proud-proxima",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node scripts/build-search-index.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "search:index": "node scripts/build-search-index.mjs",
    "docs:sync-kamae": "node scripts/sync-kamae-docs.mjs",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "r2:upload-assets": "node scripts/upload-r2-assets.mjs",
