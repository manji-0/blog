{
  "name": "proud-proxima",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node scripts/build-search-index.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "search:index": "node scripts/build-search-index.mjs",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "r2:upload-assets": "node scripts/upload-r2-assets.mjs",
    "deploy:worker": "pnpm --filter site-worker run deploy",
    "cf:deploy:local": "pnpm run fonts:subset && pnpm run build && pnpm run r2:upload-assets && pnpm --filter site-worker run assemble && pnpm --filter slides run build",
    "cf:deploy": "pnpm run cf:deploy:local && pnpm --filter site-worker run deploy",
    "lint:text": "textlint \"src/content/**/*.md\"",
    "lint:text:fix": "textlint --fix \"src/content/**/*.md\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/content/**/*.md": "textlint"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/starlight": "^0.39.3",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "astro": "^6.4.3",
    "beautiful-mermaid": "^1.1.3",
    "gray-matter": "^4.0.3",
    "kuromoji": "^0.1.2",
    "sharp": "^0.34.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "textlint": "^15.7.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-preset-jtf-style": "^3.0.3",
    "wrangler": "^4.19.0"
  }
}
